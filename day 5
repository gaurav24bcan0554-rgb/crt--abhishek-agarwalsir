// ==============================================
// рЯТО PROBLEM 05: FUNCTION OVERLOADING рЯПЧпЄП
// рЯУЭ Task: Use the same name 'add' for different types/counts
// ==============================================

#include <iostream>
using namespace std;

// Adding two integers
int add(int a, int b){
    return a + b;
}

// Adding two doubles
double add(double a, double b){
    return a + b;
}

// Adding three integers
int add(int a, int b, int c){
    return a + b + c;
}

// Adding four floats
float add(float a, float b, float c, float d){
    return a + b + c + d;
}

int main() {
    cout << "Int Add (2): " << add(5, 2) << "\n";
    cout << "Double Add:   " << add(5.5, 7.9) <<"\n";
    cout << "Int Add (3): " << add(5, 2, 3) << "\n";
    cout << "Float Add(4): " << add(5.0f, 2.3f, 5.5f, 7.9f) <<"\n";
    
    return 0;
}

