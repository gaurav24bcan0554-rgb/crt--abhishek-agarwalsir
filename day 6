// 💎 PROBLEM 07: ACCESS SPECIFIER (PUBLIC) 🔓
// 📝 Task: Demonstrating the 'public' keyword for global access
// ==============================================

#include <iostream>
using namespace std;

class publicPark {
public:
    // This method is accessible from any part of the program
    void enter() {
        cout << "Anyone can enter in the park...";
    }
};

int main() {
    publicPark p;
    p.enter(); // Direct access allowed
    return 0;
}

